FROM registry.access.redhat.com/ubi9/nginx-120

# Switch to root to modify file permissions
USER root

# Copy static site files
COPY dist/ /usr/share/nginx/html/

# Ensure correct permissions and ownership
RUN chmod -R 755 /usr/share/nginx/html && \
    chown -R nginx:nginx /usr/share/nginx/html

# Expose port 8080 as per your use case
EXPOSE 8080

# Copy a custom nginx config
COPY deploy/dev/nginx.conf /etc/nginx/nginx.conf

# Switch back to nginx user (best practice)
USER nginx

# Ensure nginx listens on port 8080 (requires custom config or change default)
# Optional: copy custom config if needed
# COPY nginx.conf /etc/nginx/nginx.conf

# Run nginx in the foreground
CMD ["nginx", "-g", "daemon off;"]
